{
  "name": "@poe-worksmith/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:check": "node dist/checkDatabase.js",
    "db:check:migrations": "drizzle-kit check --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "start": "node --env-file-if-exists=../../.env.development dist/index.js",
    "start:all": "node --env-file-if-exists=../../.env.development dist/entrypoints/all.js",
    "start:api": "node --env-file-if-exists=../../.env.development dist/entrypoints/api.js",
    "start:worker": "node --env-file-if-exists=../../.env.development dist/entrypoints/worker.js",
    "test": "vitest run --passWithNoTests --exclude '**/*.integration.test.ts' --exclude 'dist/**'",
    "test:integration": "vitest run 'src/*.integration.test.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@poe-worksmith/domain": "workspace:*",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "pg": "8.22.0",
    "pg-boss": "12.26.1",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
