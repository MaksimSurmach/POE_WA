APP_ENV=development
APP_MODE=all
APP_HOST=127.0.0.1
APP_PORT=3000
LOG_LEVEL=debug
PG_BOSS_SCHEMA=pgboss
REFRESH_CRON="0 */4 * * *"
CLEANUP_CRON="15 2 * * *"
POE_LEAGUE=Mercenaries
POE_USER_AGENT="POE-Worksmith/0.0.0 (contact: local-development)"
MARKET_CONCURRENCY=4
JOB_LEASE_TIMEOUT_MS=300000
MARKET_RETRY_DELAY_MS=60000
SNAPSHOT_TTL_MS=1800000
RETENTION_BATCH_SIZE=500
SHUTDOWN_TIMEOUT_MS=30000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/poe_worksmith_dev
DATABASE_SSL_MODE=disable
DATABASE_POOL_MAX=6
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
