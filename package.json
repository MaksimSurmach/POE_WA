{
  "name": "poe-worksmith-automator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.12 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "db:check": "pnpm --filter @poe-worksmith/server build && node --env-file=.env.development apps/server/dist/checkDatabase.js",
    "db:check:migrations": "pnpm --filter @poe-worksmith/server db:check:migrations",
    "db:down": "docker compose --profile test down",
    "db:migrate": "pnpm --filter @poe-worksmith/server db:migrate",
    "db:reset": "docker compose --profile test down --volumes && pnpm db:setup",
    "db:setup": "pnpm db:up && pnpm db:migrate",
    "db:test:up": "docker compose --profile test up -d --wait postgres-test",
    "db:up": "docker compose up -d --wait postgres",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "recipes:validate": "pnpm --filter @poe-worksmith/server build && pnpm --filter @poe-worksmith/server recipes:validate",
    "recipes:sync": "pnpm --filter @poe-worksmith/server build && pnpm --filter @poe-worksmith/server recipes:sync",
    "start": "pnpm --filter @poe-worksmith/server start",
    "start:api": "pnpm --filter @poe-worksmith/server start:api",
    "start:worker": "pnpm --filter @poe-worksmith/server start:worker",
    "test": "pnpm -r --if-present test",
    "test:integration": "pnpm -r --if-present test:integration",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  }
}
