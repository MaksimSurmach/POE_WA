APP_ENV=test
APP_MODE=all
APP_HOST=127.0.0.1
APP_PORT=3001
LOG_LEVEL=silent
PG_BOSS_SCHEMA=pgboss_test
REFRESH_CRON="0 */4 * * *"
CLEANUP_CRON="15 2 * * *"
POE_LEAGUE=Mercenaries
POE_USER_AGENT="OAuth poe-worksmith/0.0.0 (contact: integration-tests)"
POE_REQUEST_TIMEOUT_MS=15000
MARKET_CONCURRENCY=2
JOB_LEASE_TIMEOUT_MS=10000
MARKET_RETRY_DELAY_MS=1000
SNAPSHOT_TTL_MS=1800000
RETENTION_BATCH_SIZE=50
SHUTDOWN_TIMEOUT_MS=30000
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54324/poe_worksmith_test
DATABASE_SSL_MODE=disable
DATABASE_POOL_MAX=4
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
