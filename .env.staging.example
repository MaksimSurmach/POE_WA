APP_ENV=staging
APP_MODE=all
APP_HOST=0.0.0.0
APP_PORT=3000
LOG_LEVEL=info
PG_BOSS_SCHEMA=pgboss
SCHEDULER_TEST_CRON="* * * * *"
SHUTDOWN_TIMEOUT_MS=30000
DATABASE_URL=postgresql://postgres.PROJECT_REF:REPLACE_WITH_DATABASE_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_SSL_MODE=require
DATABASE_POOL_MAX=6
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
