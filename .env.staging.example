APP_ENV=staging
APP_MODE=all
APP_HOST=0.0.0.0
APP_PORT=3000
LOG_LEVEL=info
PG_BOSS_SCHEMA=pgboss
REFRESH_CRON="0 */4 * * *"
CLEANUP_CRON="15 2 * * *"
POE_LEAGUE=Mercenaries
POE_USER_AGENT="OAuth poe-worksmith/0.0.0 (contact: REPLACE_WITH_CONTACT)"
MARKET_CONCURRENCY=4
JOB_LEASE_TIMEOUT_MS=300000
MARKET_RETRY_DELAY_MS=60000
SNAPSHOT_TTL_MS=1800000
RETENTION_BATCH_SIZE=500
SHUTDOWN_TIMEOUT_MS=30000
DATABASE_URL=postgresql://postgres.PROJECT_REF:REPLACE_WITH_DATABASE_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_SSL_MODE=require
DATABASE_POOL_MAX=6
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
